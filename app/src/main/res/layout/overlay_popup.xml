<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popupCard"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bubble_card_bg"
    android:padding="14dp">

    <!-- Veredicto grande y a color: se lee de un vistazo -->
    <TextView
        android:id="@+id/popupHeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONVIENE"
        android:textColor="#2BD576"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.02" />

    <!-- Numero estrella: ganancia por hora -->
    <TextView
        android:id="@+id/popupHero"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$0/h"
        android:textColor="#EAF0FF"
        android:textSize="34sp"
        android:textStyle="bold"
        android:includeFontPadding="false"
        android:paddingTop="2dp" />

    <!-- Contexto minimo -->
    <TextView
        android:id="@+id/popupSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#8A96B5"
        android:textSize="13sp"
        android:paddingTop="2dp" />

    <!-- Solo inDrive: cuanto pedir -->
    <TextView
        android:id="@+id/popupNegotiate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textColor="#2BD576"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/toggle_off"
        android:paddingVertical="8dp"
        android:layout_marginTop="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp">

        <TextView
            android:id="@+id/btnTook"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✓ Sí"
            android:gravity="center"
            android:textColor="#2BD576"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/toggle_on"
            android:paddingVertical="11dp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✗ No"
            android:gravity="center"
            android:textColor="#8A96B5"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/toggle_off"
            android:paddingVertical="11dp" />
    </LinearLayout>
</LinearLayout>
