<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popupCard"
    android:layout_width="190dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bubble_card_bg"
    android:padding="14dp">

    <!-- Simbolo gigante: se lee sin pensar -->
    <TextView
        android:id="@+id/popupSymbol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓"
        android:textColor="#2BD576"
        android:textSize="46sp"
        android:includeFontPadding="false" />

    <!-- Veredicto en palabra -->
    <TextView
        android:id="@+id/popupHeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONVIENE"
        android:textColor="#2BD576"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="2dp" />

    <!-- Contexto minimo: la tarifa, para saber de cual carrera es -->
    <TextView
        android:id="@+id/popupSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#8A96B5"
        android:textSize="13sp"
        android:paddingTop="2dp" />

    <!-- Solo inDrive: cuanto pedir -->
    <TextView
        android:id="@+id/popupNegotiate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textColor="#2BD576"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/toggle_off"
        android:paddingVertical="8dp"
        android:layout_marginTop="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp">

        <TextView
            android:id="@+id/btnTook"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✓ Sí"
            android:gravity="center"
            android:textColor="#2BD576"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/toggle_on"
            android:paddingVertical="12dp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✗ No"
            android:gravity="center"
            android:textColor="#8A96B5"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/toggle_off"
            android:paddingVertical="12dp" />
    </LinearLayout>
</LinearLayout>
