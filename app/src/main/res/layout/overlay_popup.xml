<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popupCard"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bubble_card_bg"
    android:padding="14dp">

    <TextView
        android:id="@+id/popupHeadline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CONVIENE"
        android:textColor="#2BD576"
        android:textSize="19sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/popupBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#EAF0FF"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:paddingTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿La tomaste?"
        android:textColor="#8A96B5"
        android:textSize="11sp"
        android:paddingTop="10dp"
        android:paddingBottom="5dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnTook"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✓ Sí"
            android:gravity="center"
            android:textColor="#2BD576"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/toggle_on"
            android:paddingVertical="10dp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✗ No"
            android:gravity="center"
            android:textColor="#8A96B5"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/toggle_off"
            android:paddingVertical="10dp" />
    </LinearLayout>
</LinearLayout>
