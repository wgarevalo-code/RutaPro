<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configura tus parametros y activa los dos permisos."
            android:paddingBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Pago minimo por km (viaje)" />
        <EditText android:id="@+id/minPerKm" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="numberDecimal" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Pago minimo por minuto"
            android:paddingTop="8dp" />
        <EditText android:id="@+id/minPerMin" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="numberDecimal" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Precio gasolina por galon"
            android:paddingTop="8dp" />
        <EditText android:id="@+id/fuelPrice" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="numberDecimal" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Rendimiento (km por galon)"
            android:paddingTop="8dp" />
        <EditText android:id="@+id/kmPerGallon" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="numberDecimal" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Recogida maxima aceptable (km)"
            android:paddingTop="8dp" />
        <EditText android:id="@+id/maxPickup" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="numberDecimal" />

        <Button android:id="@+id/saveBtn" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Guardar parametros"
            android:layout_marginTop="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#33000000" android:layout_marginVertical="16dp" />

        <Button android:id="@+id/overlayBtn" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="1. Permitir burbuja (overlay)" />

        <Button android:id="@+id/accessBtn" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="2. Activar accesibilidad"
            android:layout_marginTop="8dp" />

        <TextView android:id="@+id/status" android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp" android:textSize="16sp"
            android:text="Estado..." />

    </LinearLayout>
</ScrollView>
