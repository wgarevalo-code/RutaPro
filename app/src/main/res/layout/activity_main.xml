<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:text="RutaPro"
                    android:textColor="@color/cyan"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="USD $"
                    android:textColor="@color/cyan"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/chip_usd"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Panel de control"
                android:textColor="@color/textMain"
                android:textSize="26sp"
                android:textStyle="bold"
                android:paddingTop="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configura tus filtros y monitorea tus viajes"
                android:textColor="@color/textMuted"
                android:textSize="13sp" />

            <!-- Start card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_hero"
                android:padding="22dp"
                android:layout_marginTop="18dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/appsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uber · inDrive"
                        android:textColor="@color/textMuted"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/statusPill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Listo para iniciar"
                        android:textColor="@color/cyan"
                        android:textSize="12sp"
                        android:background="@drawable/pill_outline"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp" />
                </RelativeLayout>

                <ImageButton
                    android:id="@+id/startBtn"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/circle_button"
                    android:src="@drawable/ic_play"
                    android:scaleType="center"
                    android:contentDescription="Iniciar" />

                <TextView
                    android:id="@+id/startHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp"
                    android:text="Toca para iniciar el análisis"
                    android:textColor="@color/textMuted"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginTop="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout style="@style/StatCol">
                        <TextView android:id="@+id/statTotal" style="@style/StatNum"
                            android:textColor="@color/cyan" android:text="0" />
                        <TextView style="@style/StatLabel" android:text="Total" />
                    </LinearLayout>
                    <LinearLayout style="@style/StatCol">
                        <TextView android:id="@+id/statAccept" style="@style/StatNum"
                            android:textColor="@color/green" android:text="0" />
                        <TextView style="@style/StatLabel" android:text="Aceptar" />
                    </LinearLayout>
                    <LinearLayout style="@style/StatCol">
                        <TextView android:id="@+id/statReject" style="@style/StatNum"
                            android:textColor="@color/red" android:text="0" />
                        <TextView style="@style/StatLabel" android:text="Rechazar" />
                    </LinearLayout>
                </LinearLayout>
                <TextView android:id="@+id/resetStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="↺  Reiniciar contadores"
                    android:gravity="center"
                    android:background="@drawable/toggle_off"
                    android:textColor="@color/textMuted"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingVertical="11dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Filtros -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginTop="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Filtros inteligentes"
                        android:textColor="@color/textMain"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/filtersActive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="3 activos"
                        android:textColor="@color/cyan"
                        android:textSize="12sp"
                        android:background="@drawable/badge_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </RelativeLayout>

                <!-- POR HORA -->
                <LinearLayout style="@style/FilterBlock">
                    <LinearLayout android:id="@+id/hourHeader" style="@style/FilterHeader">
                        <ImageView style="@style/FilterIcon" android:src="@drawable/ic_timer" />
                        <LinearLayout style="@style/FilterMid">
                            <TextView style="@style/FilterLabel" android:text="Por hora" />
                            <LinearLayout style="@style/FilterValueRow">
                                <TextView style="@style/FilterCurr" android:text="$" />
                                <EditText android:id="@+id/minPerHour" style="@style/FilterValue" />
                            </LinearLayout>
                        </LinearLayout>
                        <TextView android:id="@+id/toggleHour" style="@style/FilterToggle" android:text="ON" />
                        <ImageView android:id="@+id/hourChevron" style="@style/FilterChevron" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/hourPanel" style="@style/FilterPanel">
                        <TextView style="@style/FilterDesc"
                            android:text="Lo mínimo que quieres ganar por cada hora trabajada, ya descontada la gasolina. Cuenta el tiempo de ir a recoger más el viaje." />
                        <LinearLayout style="@style/PresetRow">
                            <TextView android:id="@+id/hourP1" style="@style/Preset" android:text="$8" />
                            <TextView android:id="@+id/hourP2" style="@style/Preset" android:text="$10" />
                            <TextView android:id="@+id/hourP3" style="@style/Preset" android:text="$15" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- POR KM -->
                <LinearLayout style="@style/FilterBlock">
                    <LinearLayout android:id="@+id/kmHeader" style="@style/FilterHeader">
                        <ImageView style="@style/FilterIcon" android:src="@drawable/ic_trending" />
                        <LinearLayout style="@style/FilterMid">
                            <TextView style="@style/FilterLabel" android:text="Por km" />
                            <LinearLayout style="@style/FilterValueRow">
                                <TextView style="@style/FilterCurr" android:text="$" />
                                <EditText android:id="@+id/minPerKm" style="@style/FilterValue" />
                            </LinearLayout>
                        </LinearLayout>
                        <TextView android:id="@+id/toggleKm" style="@style/FilterToggle" android:text="ON" />
                        <ImageView android:id="@+id/kmChevron" style="@style/FilterChevron" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/kmPanel" style="@style/FilterPanel">
                        <TextView style="@style/FilterDesc"
                            android:text="Lo mínimo que quieres ganar por cada kilómetro del viaje, ya descontada la gasolina. Es el filtro que más pesa en viajes largos." />
                        <LinearLayout style="@style/PresetRow">
                            <TextView android:id="@+id/kmP1" style="@style/Preset" android:text="$0.35" />
                            <TextView android:id="@+id/kmP2" style="@style/Preset" android:text="$0.45" />
                            <TextView android:id="@+id/kmP3" style="@style/Preset" android:text="$0.60" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- PICKUP -->
                <LinearLayout style="@style/FilterBlock">
                    <LinearLayout android:id="@+id/pickHeader" style="@style/FilterHeader">
                        <ImageView style="@style/FilterIcon" android:src="@drawable/ic_location" />
                        <LinearLayout style="@style/FilterMid">
                            <TextView style="@style/FilterLabel" android:text="Pickup máx." />
                            <LinearLayout style="@style/FilterValueRow">
                                <EditText android:id="@+id/maxPickup" style="@style/FilterValue" />
                                <TextView style="@style/FilterCurr" android:text=" km" />
                            </LinearLayout>
                        </LinearLayout>
                        <TextView android:id="@+id/togglePickup" style="@style/FilterToggle" android:text="ON" />
                        <ImageView android:id="@+id/pickChevron" style="@style/FilterChevron" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/pickPanel" style="@style/FilterPanel">
                        <TextView style="@style/FilterDesc"
                            android:text="Qué tan lejos aceptas manejar para recoger al pasajero. Ese trayecto no te lo pagan, así que mientras más corto, mejor." />
                        <LinearLayout style="@style/PresetRow">
                            <TextView android:id="@+id/pickP1" style="@style/Preset" android:text="2 km" />
                            <TextView android:id="@+id/pickP2" style="@style/Preset" android:text="3 km" />
                            <TextView android:id="@+id/pickP3" style="@style/Preset" android:text="5 km" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- TURBO -->
                <LinearLayout style="@style/FilterBlock">
                    <LinearLayout android:id="@+id/turboHeader" style="@style/FilterHeader">
                        <ImageView style="@style/FilterIcon" android:src="@drawable/ic_star" />
                        <LinearLayout style="@style/FilterMid">
                            <TextView style="@style/FilterLabel" android:text="⚡ Turbo" />
                            <TextView android:id="@+id/turboState"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Desactivado"
                                android:textColor="@color/textMain"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:id="@+id/toggleTurbo" style="@style/FilterToggle" android:text="OFF" />
                        <ImageView android:id="@+id/turboChevron" style="@style/FilterChevron" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/turboPanel" style="@style/FilterPanel">
                        <TextView style="@style/FilterDesc"
                            android:text="Sube todas tus exigencias un 40% de golpe. Úsalo en hora pico, cuando hay tantas carreras que puedes darte el lujo de escoger solo las mejores." />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Gasolina -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛽ Costo de gasolina"
                    android:textColor="@color/textMain"
                    android:textSize="17sp"
                    android:textStyle="bold" />
                <TextView style="@style/FilterDesc"
                    android:text="Cuánto te cuesta la gasolina por cada kilómetro. Si no lo sabes, toca tu tipo de vehículo abajo y listo."
                    android:paddingTop="6dp" />

                <LinearLayout style="@style/FilterValueRow" android:paddingTop="10dp">
                    <TextView style="@style/FilterCurr" android:text="$" />
                    <EditText android:id="@+id/fuelPerKm" style="@style/FilterValue" />
                    <TextView style="@style/FilterCurr" android:text=" / km" />
                </LinearLayout>

                <LinearLayout style="@style/PresetRow">
                    <TextView android:id="@+id/fuelP1" style="@style/Preset" android:text="Moto" />
                    <TextView android:id="@+id/fuelP2" style="@style/Preset" android:text="Carro" />
                    <TextView android:id="@+id/fuelP3" style="@style/Preset" android:text="Camioneta" />
                </LinearLayout>
            </LinearLayout>

            <!-- Permisos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Permisos del sistema"
                    android:textColor="@color/textMain"
                    android:textSize="17sp"
                    android:textStyle="bold" />
                <TextView style="@style/FilterDesc"
                    android:text="RutaPro ya no usa accesibilidad. Lee la pantalla por captura, y el permiso te lo pide Android al darle iniciar."
                    android:paddingTop="6dp"
                    android:paddingBottom="12dp" />

                <TextView android:id="@+id/overlayBtn" style="@style/PermBtn"
                    android:text="Permitir ventana flotante" />
                <TextView android:id="@+id/overlayState" style="@style/PermState"
                    android:text="Sin conceder" />

                <TextView android:id="@+id/locationBtn" style="@style/PermBtn"
                    android:text="Permitir ubicación"
                    android:layout_marginTop="12dp" />
                <TextView android:id="@+id/locationState" style="@style/PermState"
                    android:text="Sin conceder" />
                <TextView style="@style/FilterDesc"
                    android:text="La ubicación es opcional: sirve para contarte los km del día y tus mejores zonas."
                    android:paddingTop="6dp" />
            </LinearLayout>

            <!-- Modo inDrive (opcional) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚗 Modo inDrive (opcional)"
                    android:textColor="@color/textMain"
                    android:textSize="17sp"
                    android:textStyle="bold" />
                <TextView style="@style/FilterDesc"
                    android:text="inDrive bloquea la captura de pantalla, así que la lectura por OCR no funciona con él. Si manejas inDrive, activa este modo: usa accesibilidad SOLO para inDrive. Si solo manejas Uber, déjalo apagado."
                    android:paddingTop="6dp"
                    android:paddingBottom="12dp" />

                <TextView android:id="@+id/indriveBtn" style="@style/PermBtn"
                    android:text="Activar lectura de inDrive" />
                <TextView android:id="@+id/indriveState" style="@style/PermState"
                    android:text="Desactivado" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/cardBorder" android:layout_marginVertical="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔬 Modo diagnóstico"
                            android:textColor="@color/textMain"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView style="@style/FilterDesc"
                            android:text="Muestra en pantalla el texto que la app logra leer. Úsalo para mandarme una foto y afinar el lector." />
                    </LinearLayout>
                    <TextView android:id="@+id/toggleDebug" style="@style/FilterToggle"
                        android:text="OFF" />
                </LinearLayout>
            </LinearLayout>

            <TextView android:id="@+id/saveBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="Guardar cambios"
                android:gravity="center"
                android:textColor="#0A0F1F"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:paddingVertical="16dp" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card"
        app:menu="@menu/bottom_nav"
        app:itemIconTint="@color/nav_tint"
        app:itemTextColor="@color/nav_tint"
        app:labelVisibilityMode="labeled" />

</LinearLayout>
